{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "WebSearch",
      "WebFetch",

      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go run *)",
      "Bash(go mod *)",
      "Bash(go vet *)",
      "Bash(go fmt *)",

      "Bash(bun test *)",
      "Bash(bun run *)",
      "Bash(bun build *)",
      "Bash(bun install *)",
      "Bash(bun add *)",
      "Bash(bun remove *)",

      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx *)",

      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",

      "Bash(uv run *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(uv sync *)",
      "Bash(uv lock *)",
      "Bash(uv pip *)",
      "Bash(uvx *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",

      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git log *)",
      "Bash(git show *)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(which *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "ask": [
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git branch -D *)",
      "Bash(docker *)",
      "Bash(brew uninstall *)",
      "Bash(brew remove *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(chmod *)",
      "Bash(chown *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/.env.*)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(npm publish *)",
      "Bash(bun publish *)",
      "Bash(uv publish *)"
    ],
    "defaultMode": "acceptEdits"
  }
}
